{
  "name": "daylist",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md,astro}\"",
    "prepare": "husky",
    "migration:generate": "pnpm --filter api migration:generate",
    "migration:run": "pnpm --filter api migration:run",
    "migration:revert": "pnpm --filter api migration:revert",
    "migration:create": "pnpm --filter api migration:create",
    "migration:show": "pnpm --filter api migration:show"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.3.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,json,md,astro}": "prettier --write"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
