{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@daylist/common/types/entities": [
        "../../packages/common/src/types/entities"
      ],
      "@daylist/common/enums": ["../../packages/common/src/enums"],
      "@lib/*": ["src/lib/*"],
      "@typeorm/*": ["src/typeorm/*"],
      "@test/*": ["src/test/*"]
    }
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
