# Database
DATABASE_URL=postgres://daylist:daylist@localhost:5432/daylist

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=3001

# Seed
# Set to "true" to populate the DB with mock data on startup (dev only)
SEED_ENABLED=false
